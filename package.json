{
  "name": "bakery",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:generate": "pnpm --filter @bakery/db drizzle-kit generate",
    "db:migrate": "pnpm --filter @bakery/db drizzle-kit migrate",
    "db:seed": "pnpm --filter @bakery/db seed",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "prettier": "^3.5.0",
    "@types/node": "^22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "bcrypt",
      "esbuild",
      "sharp"
    ]
  }
}
