{
  "name": "@bakery/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit",
    "seed:validate": "tsx scripts/upload-assets.ts --validate-only",
    "seed": "tsx src/seed.ts",
    "assets:upload": "tsx scripts/upload-assets.ts",
    "photos:upload": "tsx scripts/upload-assets.ts",
    "seed:full": "tsx scripts/upload-assets.ts && tsx src/seed.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.44.0",
    "minio": "^8.0.7",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "zod": "^3.23.0"
  }
}
