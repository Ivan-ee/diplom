%%{init: {
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Times New Roman",
    "fontSize": "15px",
    "primaryColor": "#ffffff",
    "primaryTextColor": "#111111",
    "primaryBorderColor": "#222222",
    "clusterBkg": "#ffffff",
    "clusterBorder": "#222222",
    "lineColor": "#333333",
    "edgeLabelBackground": "#ffffff",
    "tertiaryColor": "#f7f7f7"
  },
  "flowchart": {
    "htmlLabels": false,
    "curve": "basis",
    "nodeSpacing": 32,
    "rankSpacing": 48,
    "defaultRenderer": "elk"
  }
}}%%
flowchart TD
  subgraph public["Публичный контур"]
    direction TB
    home["Главная страница"]
    catalog["Каталог товаров"]
    product["Карточка товара"]
    constructor["3D-конструктор"]
    cart["Корзина"]
    auth["Вход и регистрация"]
    checkout["Оформление заказа"]
    confirm["Подтверждение заказа"]
  end

  subgraph account["Личный кабинет"]
    direction TB
    accountHome["Профиль пользователя"]
    history["История заказов"]
    orderDetail["Карточка заказа"]
    favorites["Избранное"]
  end

  subgraph admin["Административный контур"]
    direction TB
    adminHome["Дашборд"]
    adminOrders["Заказы"]
    adminProducts["Товары и категории"]
    adminIngredients["Ингредиенты конструктора"]
    adminUsers["Пользователи"]
    adminPromos["Промокоды"]
  end

  home --> catalog
  home --> constructor
  home --> auth
  home --> accountHome

  catalog --> product
  product --> cart
  constructor --> cart

  cart --> catalog
  cart --> checkout
  checkout --> auth
  auth --> checkout
  checkout --> confirm
  confirm --> accountHome

  accountHome --> history
  accountHome --> favorites
  history --> orderDetail

  adminHome --> adminOrders
  adminHome --> adminProducts
  adminHome --> adminIngredients
  adminHome --> adminUsers
  adminHome --> adminPromos

  classDef screen fill:#f7f7f7,stroke:#555555,stroke-width:1.4px,color:#111111;
  classDef entry fill:#ffffff,stroke:#222222,stroke-width:1.6px,color:#111111;

  class home,adminHome entry;
  class catalog,product,constructor,cart,auth,checkout,confirm,accountHome,history,orderDetail,favorites,adminOrders,adminProducts,adminIngredients,adminUsers,adminPromos screen;
