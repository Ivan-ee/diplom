%%{init: {
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Times New Roman",
    "primaryColor": "#ffffff",
    "primaryTextColor": "#111111",
    "primaryBorderColor": "#222222",
    "clusterBkg": "#ffffff",
    "clusterBorder": "#222222",
    "lineColor": "#333333",
    "edgeLabelBackground": "#ffffff",
    "tertiaryColor": "#f7f7f7"
  },
  "flowchart": {
    "htmlLabels": false,
    "curve": "basis",
    "nodeSpacing": 42,
    "rankSpacing": 72
  }
}}%%
flowchart LR
  user["Пользователь"]

  subgraph client["Клиентская часть"]
    direction TB
    storefront["Публичная витрина"]
    catalogUI["Каталог и карточка товара"]
    constructorUI["3D-конструктор"]
    cartUI["Корзина и оформление"]
    accountUI["Личный кабинет"]
    adminUI["Административные экраны"]
  end

  api["Прикладной интерфейс"]

  subgraph server["Серверная часть"]
    direction TB
    catalogModule["Модуль каталога"]
    authModule["Модуль авторизации"]
    orderModule["Модуль заказов"]
    constructorModule["Модуль конструктора"]
    fileModule["Модуль загрузки файлов"]
    discountSearchModule["Промокоды и поиск"]
    adminModule["Администрирование"]
  end

  subgraph external["Внешние контуры"]
    direction TB
    dataStorage["Реляционное хранилище"]
    fileStorage["Файловое хранилище"]
    searchStorage["Поисковая подсистема"]
  end

  user -->|"запросы"| storefront
  catalogUI --> api
  constructorUI --> api
  cartUI --> api
  accountUI --> api
  adminUI --> api

  api --> catalogModule
  api --> authModule
  api --> orderModule
  api --> constructorModule
  api --> fileModule
  api --> discountSearchModule
  api --> adminModule

  catalogModule -->|"товары"| dataStorage
  authModule -->|"пользователи"| dataStorage
  orderModule -->|"заказы"| dataStorage
  constructorModule -->|"параметры изделия"| dataStorage
  fileModule -->|"изображения"| fileStorage
  discountSearchModule -->|"индекс каталога"| searchStorage

  classDef actor fill:#ffffff,stroke:#222222,stroke-width:2px,color:#111111;
  classDef component fill:#f7f7f7,stroke:#555555,stroke-width:1.4px,color:#111111;
  classDef interface fill:#ffffff,stroke:#222222,stroke-width:2px,color:#111111;
  classDef externalNode fill:#ffffff,stroke:#555555,stroke-width:1.4px,stroke-dasharray: 6 5,color:#111111;

  class user actor;
  class storefront,catalogUI,constructorUI,cartUI,accountUI,adminUI,catalogModule,authModule,orderModule,constructorModule,fileModule,discountSearchModule,adminModule component;
  class api interface;
  class dataStorage,fileStorage,searchStorage externalNode;
