%%{init: {
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Times New Roman",
    "fontSize": "15px",
    "primaryColor": "#ffffff",
    "primaryTextColor": "#111111",
    "primaryBorderColor": "#222222",
    "lineColor": "#333333",
    "textColor": "#111111",
    "mainBkg": "#ffffff",
    "clusterBkg": "#fafafa",
    "clusterBorder": "#888888",
    "edgeLabelBackground": "#ffffff",
    "nodeTextColor": "#111111"
  },
  "flowchart": {
    "htmlLabels": true,
    "curve": "linear",
    "nodeSpacing": 30,
    "rankSpacing": 38,
    "padding": 6
  }
}}%%
flowchart TD
  START((" ")):::initial
  INIT["Инициализация сцены и загрузка<br/>каталога ингредиентов"]:::action
  FB{"Каталог<br/>доступен?"}:::decision
  LOCAL["Использовать локальный<br/>резервный каталог"]:::action
  RESTORE["Восстановление состояния<br/>из sessionStorage"]:::action

  S1["Шаг 1. Форма и количество ярусов"]:::step
  V1{"Параметры<br/>шага заполнены?"}:::decision
  S2["Шаг 2. Основа и вес каждого яруса"]:::step
  V2{"Параметры<br/>шага заполнены?"}:::decision
  S3["Шаг 3. Начинка каждого яруса"]:::step
  V3{"Параметры<br/>шага заполнены?"}:::decision
  S4["Шаг 4. Покрытие и режим оформления"]:::step
  V4{"Параметры<br/>шага заполнены?"}:::decision
  S5["Шаг 5. Декор, свеча и текст надписи"]:::step
  V5{"Конфигурация<br/>полна?"}:::decision

  SHOT["Формирование скриншота 3D-сцены"]:::action
  PRESIGN["Запрос presigned URL<br/>POST /api/upload/presign"]:::action
  UPLOAD["Загрузка изображения<br/>в объектное хранилище"]:::action
  ADD["Добавление позиции типа<br/>constructor в корзину"]:::action

  END(((" "))):::final

  START --> INIT --> FB
  FB -- "нет" --> LOCAL --> RESTORE
  FB -- "да" --> RESTORE
  RESTORE --> S1

  S1 --> V1
  V1 -- "нет" --> S1
  V1 -- "да" --> S2

  S2 --> V2
  V2 -- "нет" --> S2
  V2 -- "да" --> S3

  S3 --> V3
  V3 -- "нет" --> S3
  V3 -- "да" --> S4

  S4 --> V4
  V4 -- "нет" --> S4
  V4 -- "да" --> S5

  S5 --> V5
  V5 -- "нет" --> S5
  V5 -- "да" --> SHOT

  SHOT --> PRESIGN --> UPLOAD --> ADD --> END

  classDef initial fill:#111111,stroke:#111111,color:#111111;
  classDef final   fill:#ffffff,stroke:#111111,stroke-width:2px,color:#111111;
  classDef action  fill:#ffffff,stroke:#222222,stroke-width:1.2px,color:#111111;
  classDef step    fill:#f4f4f4,stroke:#222222,stroke-width:1.2px,color:#111111;
  classDef decision fill:#ffffff,stroke:#222222,stroke-width:1.4px,color:#111111;
