erDiagram

  "Пользователь" ||--o{ "Заказ" : "оформляет"
  "Пользователь" ||--o{ "Избранное" : "добавляет"
  "Пользователь" ||--o{ "Использование промокода" : "применяет"

  "Категория" ||--o{ "Товар" : "содержит"
  "Товар" ||--o{ "Связь товара и повода" : "относится"
  "Повод" ||--o{ "Связь товара и повода" : "относится"
  "Товар" ||--o{ "Избранное" : "входит"
  "Товар" ||--o{ "Позиция заказа" : "покупается как"

  "Заказ" ||--|{ "Позиция заказа" : "включает"
  "Заказ" }o--o| "Промокод" : "применяется"
  "Заказ" ||--o{ "Использование промокода" : "регистрируется"
  "Промокод" ||--o{ "Использование промокода" : "учитывается"

  "Пользователь" {
    идентиф id PK
    текст имя
    текст электронная_почта
    текст телефон
    хеш парольный_хеш
    перечисл роль
  }

  "Категория" {
    идентиф id PK
    текст название
    текст псевдоним_URL
  }

  "Повод" {
    идентиф id PK
    текст название
    текст псевдоним_URL
  }

  "Товар" {
    идентиф id PK
    текст псевдоним_URL
    текст название
    текст описание
    текст состав
    текст основное_изображение
    список дополнительные_изображения
    перечисл тип_цены
    число цена_за_кг
    число цена_за_штуку
    дробное минимальный_вес
    дробное максимальный_вес
    дробное шаг_веса
    идентиф id_категории FK
    флаг доступен
  }

  "Связь товара и повода" {
    идентиф id_товара FK
    идентиф id_повода FK
  }

  "Заказ" {
    идентиф id PK
    счётчик номер_заказа
    идентиф id_пользователя FK
    перечисл статус
    число итоговая_цена
    дата дата_получения
    перечисл слот_получения
    текст телефон
    текст комментарий
    идентиф id_промокода FK
    число размер_скидки
    число цена_до_скидки
  }

  "Позиция заказа" {
    идентиф id PK
    идентиф id_заказа FK
    перечисл тип_позиции
    идентиф id_товара FK
    объект конфигурация_торта
    дробное вес
    число количество
    число цена
    текст текст_надписи
    текст ссылка_на_изображение
  }

  "Промокод" {
    идентиф id PK
    текст код
    перечисл тип_скидки
    число размер_скидки
    число минимальная_сумма_заказа
    число максимальный_размер_скидки
    дата_время начало_действия
    дата_время окончание_действия
    число лимит_использований
    число лимит_на_пользователя
    флаг активен
    текст описание
  }

  "Использование промокода" {
    идентиф id PK
    идентиф id_промокода FK
    идентиф id_пользователя FK
    идентиф id_заказа FK
    число применённый_размер_скидки
  }

  "Избранное" {
    идентиф id_пользователя FK
    идентиф id_товара FK
  }

  "Отзыв" {
    идентиф id PK
    текст имя_автора
    текст текст_отзыва
    число оценка
    флаг опубликован
  }

  "Основа" {
    идентиф id PK
    текст название
    текст описание
    число цена_за_кг
    текст текстура
    текст цвет
    флаг доступна
  }

  "Начинка" {
    идентиф id PK
    текст название
    текст описание
    перечисл категория
    число цена_за_кг
    текст изображение
    флаг доступна
  }

  "Покрытие" {
    идентиф id PK
    текст название
    перечисл тип
    число цена_за_кг
    дробное шероховатость
    флаг доступно
  }

  "Украшение" {
    идентиф id PK
    текст название
    перечисл категория
    число цена_за_штуку
    текст ссылка_на_модель
    текст миниатюра
    флаг доступно
  }
